///|
// Spec grouping:
// - T.814 VLC lookup tables for HT cleanup pass decoding

///|
let ht_vlc_tbl0_b64 = ""

///|
let ht_vlc_tbl1_b64 = ""

///|
fn ht_unpack_be_u16_table(bytes : Bytes) -> Array[Int] {
  let out : Array[Int] = []
  let mut i = 0
  while i + 1 < bytes.length() {
    out.push((bytes[i].to_int() << 8) | bytes[i + 1].to_int())
    i += 2
  }
  out
}

///|
fn ht_build_vlc_tbl0() -> Array[Int] {
  let table = ht_unpack_be_u16_table(@base64.decode_lossy(ht_vlc_tbl0_b64))
  // T.814 Table B.1: VLC lookup table patches for cleanup pass.
  table[740] = 0xF2FD
  table[741] = 0x226E
  table
}

///|
let ht_vlc_tbl0 : Array[Int] = ht_build_vlc_tbl0()

///|
let ht_vlc_tbl1 : Array[Int] = ht_unpack_be_u16_table(
  @base64.decode_lossy(ht_vlc_tbl1_b64),
)
